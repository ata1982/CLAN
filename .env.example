# Vercel環境変数設定のサンプル
# 実際の値は Vercel ダッシュボードで設定してください

# 🔒 セキュリティ設定ガイド
# このファイルは機密情報を含みません - 設定例のみです

# ===========================================
# 本番環境 (Vercel Dashboard で設定)
# ===========================================
NODE_ENV=production
NEXTAUTH_URL=https://your-domain.vercel.app/
NEXTAUTH_SECRET=generate-secure-random-string-here

# Next.js公開変数 (NEXT_PUBLIC_プレフィックス必須)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_APP_NAME=Your App Name
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ===========================================
# 開発環境 (.env.local で設定 - gitignoreされる)
# ===========================================
# NODE_ENV=development
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=local-development-secret-key

# ===========================================
# API設定例 (実際の値は別途設定)
# ===========================================
# メール送信 (Nodemailer/SendGrid等)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# データベース
# DATABASE_URL=postgresql://user:pass@host:port/dbname
# REDIS_URL=redis://user:pass@host:port

# 外部サービス
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLIC_KEY=pk_live_...
# SENDGRID_API_KEY=SG...
# GOOGLE_CLIENT_ID=xxx.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx

# ===========================================
# セキュリティ注意事項
# ===========================================
# 1. 実際のAPIキーは絶対にこのファイルに書かない
# 2. .env.local は自動的にgitignoreされる
# 3. 本番環境の値はVercel Dashboardで設定
# 4. GitHub SecretsにはCI/CD用の値のみ設定
# 5. NEXT_PUBLIC_プレフィックスの変数はクライアントサイドで公開される

# ======================================
# GitHub Secrets (Repository Settings)
# ======================================
# 以下はGitHub Repository → Settings → Secrets and variables → Actions で設定

# Vercel API設定 (必須)
# VERCEL_TOKEN=your-vercel-token
# VERCEL_PROJECT_ID=your-project-id  
# VERCEL_ORG_ID=your-org-id
