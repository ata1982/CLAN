# Vercel環境変数設定のサンプル
# 実際の値は Vercel ダッシュボードで設定してください

# Production環境設定
NODE_ENV=production

# Next.js設定
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
NEXT_PUBLIC_APP_NAME=NextJS Migration

# メール設定（Nodemailerを使用している場合）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# 認証設定（NextAuth.jsを使用する場合）
# NEXTAUTH_SECRET=your-secret-key-here
# NEXTAUTH_URL=https://your-domain.vercel.app

# データベース（使用する場合）
# DATABASE_URL=your-database-url-here

# API Keys（使用する場合）
# STRIPE_SECRET_KEY=sk_live_...
# SENDGRID_API_KEY=SG...

# カスタム環境変数
# CUSTOM_API_URL=https://api.example.com
# CUSTOM_KEY=your-custom-value

# ======================================
# GitHub Secrets (Repository Settings)
# ======================================
# 以下はGitHub Repository → Settings → Secrets and variables → Actions で設定

# Vercel API設定 (必須)
# VERCEL_TOKEN=your-vercel-token
# VERCEL_PROJECT_ID=your-project-id  
# VERCEL_ORG_ID=your-org-id
