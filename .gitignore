# ===========================================
# 🔒 セキュリティ強化: 機密情報保護
# ===========================================

# 環境変数ファイル（すべてのバリエーション）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.environment
config.json
secrets.json

# API キー・トークンファイル
**/api-keys.json
**/secrets.json
**/config.json
**/.secrets
**/tokens.txt
**/*-key.pem
**/*-cert.pem
**/private-key*
**/public-key*

# データベース関連
database.json
db.json
*.db
*.sqlite
*.sqlite3

# バックアップファイル
*.bak
*.backup
*.tmp
*.temp

# デプロイ設定
.vercel
.now
.firebase
.gcloud
deployment-config.json

# テストデータ
test-data/
mock-data/
fixtures/
**/test-secrets.*

# ログファイル
*.log
logs/
log/

# 一時ファイル
tmp/
temp/
.cache/

# macOS固有
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Windows固有
Thumbs.db
Desktop.ini

# Linux固有
*~

